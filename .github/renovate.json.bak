{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "labels": [
    "dependencies"
  ],
  "helm-requirements": {
    "fileMatch": [
      "\\Chart.yaml|requirements.yaml$"
    ],
    "aliases": {
      "hmctsprod": "https://hmctsprod.azurecr.io/helm/v1/repo/"
    }
  },
  "extends": [
    "local>hmcts/.github:renovate-config"
  ]
}
